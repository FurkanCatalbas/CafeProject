# Copy this file to backend/music-service/.env for local runs only.
# Do not commit a real .env file. The root .gitignore already ignores it.

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:10101/music-service/api/music-votes/spotify/callback

# Public URL encoded into generated QR codes.
MUSIC_VOTE_PUBLIC_URL_TEMPLATE=http://127.0.0.1:3000/music-vote/%s

# Gateway URL used when returning the QR PNG endpoint.
MUSIC_VOTE_GATEWAY_BASE_URL=http://127.0.0.1:10101

# Optional production database settings.
# MUSIC_VOTE_DB_URL=jdbc:postgresql://localhost:5432/music_vote
# MUSIC_VOTE_DB_USERNAME=postgres
# MUSIC_VOTE_DB_PASSWORD=change_me
# MUSIC_VOTE_DB_DRIVER=org.postgresql.Driver
# MUSIC_VOTE_DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect
